{
  "name": "@dpeek/graphle-live",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./out/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./out/index.js"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./out/server/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "clean": "rm -rf out",
    "check": "oxlint --type-aware --type-check --fix src --ignore-pattern '**/*.test.ts' && oxfmt && bun test ./src"
  },
  "dependencies": {
    "@dpeek/graphle-client": "workspace:*",
    "@dpeek/graphle-projection": "workspace:*",
    "@dpeek/graphle-sync": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  }
}
