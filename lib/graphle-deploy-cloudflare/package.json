{
  "name": "@dpeek/graphle-deploy-cloudflare",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./out/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./out/index.js"
    },
    "./worker": {
      "types": "./src/worker.ts",
      "default": "./out/worker.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "clean": "rm -rf out",
    "check": "oxlint --type-aware --type-check --fix src --ignore-pattern '**/*.test.ts' && oxfmt && bun test"
  },
  "dependencies": {
    "@dpeek/graphle-kernel": "workspace:*",
    "@dpeek/graphle-module": "workspace:*",
    "@dpeek/graphle-module-core": "workspace:*",
    "@dpeek/graphle-module-site": "workspace:*",
    "@dpeek/graphle-site-web": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@dpeek/graphle-bootstrap": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  }
}
